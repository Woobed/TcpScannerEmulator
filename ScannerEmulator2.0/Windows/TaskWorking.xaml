<UserControl x:Class="ScannerEmulator2._0.Windows.TaskWorking"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:ScannerEmulator2._0.ViewModels"
             mc:Ignorable="d">
    <Border Background="White" Padding="10">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Text="📋 Активные задачи"
                       FontSize="24"
                       FontWeight="Bold"
                       Margin="0,0,0,12"/>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="TasksPanel" ItemsSource="{Binding TaskList}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:TaskViewModel}">
                            <Border BorderThickness="1" CornerRadius="6" Margin="4" Padding="8" BorderBrush="#DDD" Background="#FAFAFA">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Text="{Binding Name}" FontWeight="Bold" FontSize="14"/>

                                    <StackPanel Grid.Row="1" Orientation="Vertical" Margin="0,4,0,4">
                                        <ProgressBar Value="{Binding Progress.Value}" Minimum="0" Maximum="100" Height="15" Background="#EEE">
                                            <ProgressBar.Foreground>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                    <GradientStop Color="#4CAF50" Offset="0"/>
                                                    <GradientStop Color="#8BC34A" Offset="1"/>
                                                </LinearGradientBrush>
                                            </ProgressBar.Foreground>
                                        </ProgressBar>
                                        <TextBlock Text="{Binding Progress.Value, StringFormat=Прогресс: {0}%}" FontSize="11" Foreground="Gray"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,4,0,0">

                                        <Button Content="▶ Старт"
                                                
                                                IsEnabled="{Binding State.Value}"
                                                Click="Start_Click"
                                                Tag="{Binding Id}"
                                                Padding="6,2"
                                                Margin="0,0,4,0"/>
                                        <Button Content="⏸ Пауза"
                                                IsEnabled="{Binding CanPause.Value}"
                                                Click="Pause_Click"
                                                Tag="{Binding Id}"
                                                Padding="6,2"
                                                Margin="0,0,4,0"/>
                                        <Button Content="⏵ Продолжить"
                                                IsEnabled="{Binding CanResume.Value}"
                                                Click="Resume_Click"
                                                Tag="{Binding Id}"
                                                Padding="6,2"
                                                Margin="0,0,4,0"/>
                                        <Button Content="⏹ Стоп"
                                                IsEnabled="{Binding CanStop.Value}"
                                                Click="Stop_Click"
                                                Tag="{Binding Id}"
                                                Padding="6,2"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Border>
</UserControl>
